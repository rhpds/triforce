FROM maven:3.9-eclipse-temurin-21 AS builder

WORKDIR /build
COPY pom.xml .
RUN mvn dependency:go-offline -q
COPY src src
RUN mvn package -DskipTests -Dquarkus.package.jar.type=uber-jar -q

FROM registry.access.redhat.com/ubi9/openjdk-21-runtime:1.20-2.1719294888

COPY --from=builder /build/target/*-runner.jar /deployments/app.jar

ENV JAVA_APP_JAR="/deployments/app.jar"

USER 185
EXPOSE 8082

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s \
    CMD curl -f http://localhost:8082/health || exit 1

ENTRYPOINT ["java", "-jar", "/deployments/app.jar"]
