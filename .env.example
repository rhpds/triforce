# Triforce — Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# LiteLLM inference endpoint (reuses MAAS from partner demo)
LITELLM_API_BASE=https://maas-rhdp.apps.maas.redhatworkshops.io
LITELLM_API_KEY=

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=triforce
POSTGRES_USER=triforce
POSTGRES_PASSWORD=dev-only

# Kafka (Redpanda for local dev)
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# Service ports
HEALTHCARE_PORT=8081
FINSERV_PORT=8082
ORCHESTRATOR_PORT=8083
A2A_STUB_PORT=8090
MCP_STUB_PORT=8091
