{
  "name": "finserv-tools",
  "description": "MCP tools for financial services agent — risk profiles, regulatory rules, sanctions",
  "tools": [
    {
      "name": "risk_profile_lookup",
      "description": "Look up a customer's risk profile including transaction history summary and risk factors.",
      "inputSchema": {
        "type": "object",
        "required": ["customer_id"],
        "properties": {
          "customer_id": {
            "type": "string",
            "description": "Customer identifier"
          },
          "lookback_days": {
            "type": "integer",
            "minimum": 1,
            "maximum": 365,
            "default": 90
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["customer_id", "risk_score", "risk_level", "transaction_summary"],
        "properties": {
          "customer_id": { "type": "string" },
          "risk_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "risk_level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "account_age_days": { "type": "integer" },
          "transaction_summary": {
            "type": "object",
            "properties": {
              "count": { "type": "integer" },
              "total_amount": { "type": "number" },
              "avg_amount": { "type": "number" },
              "max_amount": { "type": "number" },
              "unique_recipients": { "type": "integer" },
              "unique_countries": { "type": "integer" }
            }
          },
          "flags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    {
      "name": "regulatory_rule_check",
      "description": "Evaluate a transaction against a specific regulatory rule set.",
      "inputSchema": {
        "type": "object",
        "required": ["transaction_id", "regulation"],
        "properties": {
          "transaction_id": {
            "type": "string",
            "format": "uuid"
          },
          "regulation": {
            "type": "string",
            "enum": ["aml", "kyc", "ofac", "pci_dss", "gdpr", "sox"]
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["transaction_id", "regulation", "status", "rules_evaluated"],
        "properties": {
          "transaction_id": { "type": "string" },
          "regulation": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail", "review_required"] },
          "rules_evaluated": { "type": "integer" },
          "failures": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "rule_id": { "type": "string" },
                "description": { "type": "string" },
                "threshold": { "type": "string" },
                "actual": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "name": "sanction_list_search",
      "description": "Screen an entity against OFAC and other sanctions lists (synthetic data).",
      "inputSchema": {
        "type": "object",
        "required": ["entity_name"],
        "properties": {
          "entity_name": {
            "type": "string",
            "description": "Name of person or organization to screen"
          },
          "entity_type": {
            "type": "string",
            "enum": ["individual", "organization"],
            "default": "individual"
          },
          "country": {
            "type": "string",
            "pattern": "^[A-Z]{2}$",
            "description": "ISO 3166-1 alpha-2 country code"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["entity_name", "matches"],
        "properties": {
          "entity_name": { "type": "string" },
          "matches": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["list", "matched_name", "score"],
              "properties": {
                "list": { "type": "string" },
                "matched_name": { "type": "string" },
                "score": { "type": "number", "minimum": 0, "maximum": 1 },
                "country": { "type": "string" },
                "reason": { "type": "string" }
              }
            }
          },
          "screened": { "type": "boolean" }
        }
      }
    }
  ]
}
